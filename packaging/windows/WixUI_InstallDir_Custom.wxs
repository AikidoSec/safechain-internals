<?xml version="1.0" encoding="UTF-8"?>
<!--
  Custom WixUI_InstallDir variant with Aikido Token dialog.
  Based on WixUI_InstallDir from the WiX Toolset (Microsoft Reciprocal License).

  First-time install dialog sequence:
   - WelcomeDlg
   - LicenseAgreementDlg
   - InstallDirDlg
   - AikidoTokenDlg  (skipped when AIKIDO_TOKEN is provided via CLI)
   - VerifyReadyDlg

  Maintenance dialog sequence:
   - MaintenanceWelcomeDlg
   - MaintenanceTypeDlg
   - VerifyReadyDlg
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
    <Fragment>
        <UI Id="WixUI_InstallDir_Custom">
            <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
            <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
            <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="9" Bold="yes" />

            <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />

            <DialogRef Id="BrowseDlg" />
            <DialogRef Id="DiskCostDlg" />
            <DialogRef Id="ErrorDlg" />
            <DialogRef Id="FatalError" />
            <DialogRef Id="FilesInUse" />
            <DialogRef Id="MsiRMFilesInUse" />
            <DialogRef Id="PrepareDlg" />
            <DialogRef Id="ProgressDlg" />
            <DialogRef Id="ResumeDlg" />
            <DialogRef Id="UserExit" />

            <!-- Aikido Token Dialog -->
            <Dialog Id="AikidoTokenDlg" Width="370" Height="270" Title="[ProductName] Setup">
                <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
                <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
                <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

                <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Aikido Token" />
                <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="Enter your Aikido authentication token." />

                <Control Id="TokenLabel" Type="Text" X="20" Y="60" Width="330" Height="30" NoPrefix="yes"
                         Text="Enter the Aikido token used to authenticate this agent with the Aikido platform:" />
                <Control Id="TokenEdit" Type="Edit" X="20" Y="100" Width="330" Height="18" Property="AIKIDO_TOKEN" />

                <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
                <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)" />
                <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)" />
            </Dialog>

            <!-- ExitDialog -->
            <Publish Dialog="ExitDialog" Control="Finish" Event="EndDialog" Value="Return" Order="999" />

            <!-- WelcomeDlg -->
            <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="LicenseAgreementDlg" Condition="NOT Installed" />
            <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Condition="Installed AND PATCH" />

            <!-- LicenseAgreementDlg -->
            <Publish Dialog="LicenseAgreementDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" />
            <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg" Condition="LicenseAccepted = &quot;1&quot;" />

            <!-- InstallDirDlg: Next goes to AikidoTokenDlg or VerifyReadyDlg depending on CLI token -->
            <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog" Value="LicenseAgreementDlg" />
            <Publish Dialog="InstallDirDlg" Control="Next" Event="CheckTargetPath" Value="[WIXUI_INSTALLDIR]" Order="1" />
            <Publish Dialog="InstallDirDlg" Control="Next" Event="SetTargetPath" Value="[WIXUI_INSTALLDIR]" Order="2" />
            <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Order="3" Condition="AIKIDO_TOKEN_FROM_CLI" />
            <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="AikidoTokenDlg" Order="4" Condition="NOT AIKIDO_TOKEN_FROM_CLI" />
            <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Property="_BrowseProperty" Value="[WIXUI_INSTALLDIR]" Order="1" />
            <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Event="SpawnDialog" Value="BrowseDlg" Order="2" />

            <!-- BrowseDlg -->
            <Publish Dialog="BrowseDlg" Control="OK" Event="SetTargetPath" Value="[_BrowseProperty]" Order="1" />
            <Publish Dialog="BrowseDlg" Control="OK" Event="EndDialog" Value="Return" Order="2" />

            <!-- AikidoTokenDlg: Next requires a non-empty token -->
            <Publish Dialog="AikidoTokenDlg" Control="Back" Event="NewDialog" Value="InstallDirDlg" />
            <Publish Dialog="AikidoTokenDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Condition="AIKIDO_TOKEN" />
            <Publish Dialog="AikidoTokenDlg" Control="Cancel" Event="SpawnDialog" Value="CancelDlg" />

            <!-- VerifyReadyDlg: Back goes to AikidoTokenDlg or InstallDirDlg depending on CLI token -->
            <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="AikidoTokenDlg" Order="1" Condition="NOT Installed AND NOT AIKIDO_TOKEN_FROM_CLI" />
            <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="InstallDirDlg" Order="1" Condition="NOT Installed AND AIKIDO_TOKEN_FROM_CLI" />
            <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg" Order="2" Condition="Installed AND NOT PATCH" />
            <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="2" Condition="Installed AND PATCH" />

            <!-- Maintenance dialogs -->
            <Publish Dialog="MaintenanceWelcomeDlg" Control="Next" Event="NewDialog" Value="MaintenanceTypeDlg" />
            <Publish Dialog="MaintenanceTypeDlg" Control="RepairButton" Event="NewDialog" Value="VerifyReadyDlg" />
            <Publish Dialog="MaintenanceTypeDlg" Control="RemoveButton" Event="NewDialog" Value="VerifyReadyDlg" />
            <Publish Dialog="MaintenanceTypeDlg" Control="Back" Event="NewDialog" Value="MaintenanceWelcomeDlg" />

            <Property Id="ARPNOMODIFY" Value="1" />
        </UI>

        <UIRef Id="WixUI_Common" />
    </Fragment>
</Wix>
