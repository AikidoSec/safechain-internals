<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package Name="Aikido Endpoint Protection"
           Manufacturer="Aikido Security BV"
           Version="$(var.Version)"
           ProductCode="*"
           UpgradeCode="adb9d7b9-de00-4953-af0e-9c1e9ec15c81"
           Scope="perMachine">

    <Icon Id="SafeChainIcon.ico" SourceFile="$(var.ProjectDir)\packaging\shared\resources\SafeChain.ico" />
    <Property Id="ARPPRODUCTICON" Value="SafeChainIcon.ico" />
    <Property Id="AIKIDO_TOKEN" Secure="yes" />
    <SetProperty Id="AIKIDO_TOKEN_FROM_CLI" Value="1" Before="CostInitialize" Sequence="ui" Condition="AIKIDO_TOKEN" />

    <MajorUpgrade Schedule="afterInstallValidate" DowngradeErrorMessage="A newer version of Aikido Endpoint Protection is already installed." AllowSameVersionUpgrades="yes" />

    <Media Id="1" Cabinet="EndpointProtection.cab" EmbedCab="yes" />

    <!-- Define installation directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="AikidoSecurity">
        <Directory Id="AGENTDIR" Name="EndpointProtection">
          <Directory Id="BINDIR" Name="bin" />
          <Directory Id="SCRIPTSDIR" Name="scripts" />
          <?if $(var.IncludeDriver) = "1" ?>
          <Directory Id="DRIVERDIR" Name="driver" />
          <?endif?>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- ProgramData directory for cleanup on uninstall -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="APPDATAAIKIDO" Name="AikidoSecurity">
        <Directory Id="APPDATAAGENT" Name="EndpointProtection">
          <Directory Id="APPDATALOGSDIR" Name="logs" />
          <Directory Id="APPDATARUNDIR" Name="run" />
          <Directory Id="APPDATABINDIR" Name="bin" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Main feature -->
    <Feature Id="MainFeature" Title="Aikido Endpoint Protection" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="PathComponent" />
      <ComponentRef Id="CleanupProgramData" />
      <ComponentRef Id="StoreTokenScript" />
      <?if $(var.IncludeDriver) = "1" ?>
      <ComponentGroupRef Id="DriverComponents" />
      <ComponentRef Id="InstallDriverScript" />
      <ComponentRef Id="UninstallDriverScript" />
      <?endif?>
    </Feature>

    <!-- Components -->
    <ComponentGroup Id="ProductComponents" Directory="BINDIR">
      <Component Id="AikidoAgentExe" Guid="3a2f5c8e-e57f-4ce4-ab7f-fa89e94c48cb">
        <File Id="AikidoAgentExeFile" Source="$(var.BinDir)\EndpointProtection.exe" KeyPath="yes" />
        <ServiceInstall Id="EndpointProtectionService"
                        Name="EndpointProtection"
                        DisplayName="Aikido Endpoint Protection"
                        Description="Aikido Security Aikido Endpoint Protection - monitors and secures the software supply chain"
                        Start="auto"
                        Type="ownProcess"
                        ErrorControl="normal"
                        Account="LocalSystem" />
        <util:ServiceConfig
                        ServiceName="EndpointProtection"
                        FirstFailureActionType="restart"
                        SecondFailureActionType="restart"
                        ThirdFailureActionType="restart"
                        RestartServiceDelayInSeconds="60"
                        ResetPeriodInDays="1" />
        <ServiceControl Id="EndpointProtectionServiceControl"
                        Name="EndpointProtection"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
      <Component Id="EndpointProtectionUIExe" Guid="ceafd8b2-da4d-4c92-ace7-8736cdd67162">
        <File Id="EndpointProtectionUIExe" Source="$(var.BinDir)\EndpointProtectionUI.exe" KeyPath="yes" />
      </Component>
      <Component Id="SafeChainL7ProxyExe" Guid="8a745110-05f7-4bb8-8013-5fca733409ef">
        <File Id="SafeChainL7ProxyExeFile" Source="$(var.BinDir)\SafeChainL7Proxy.exe" KeyPath="yes" />
      </Component>
      <?if $(var.IncludeDriver) = "1" ?>
      <Component Id="SafeChainL4ProxyExe" Guid="e74a8b9c-7d2e-4cf5-8a9b-cdef01234567">
        <File Id="SafeChainL4ProxyExeFile" Source="$(var.BinDir)\SafeChainL4Proxy.exe" KeyPath="yes" />
      </Component>
      <?endif?>
    </ComponentGroup>

    <?if $(var.IncludeDriver) = "1" ?>
    <!-- Kernel-mode L4 driver bundle (sys + inf + cat + self-signed cer) -->
    <ComponentGroup Id="DriverComponents" Directory="DRIVERDIR">
      <Component Id="DriverSys" Guid="8f1a2b3c-4d5e-4f89-ab12-c3d4e5f60718">
        <File Id="DriverSysFile" Source="$(var.BinDir)\driver\safechain_lib_l4_proxy_windows_driver.sys" KeyPath="yes" />
      </Component>
      <Component Id="DriverInf" Guid="7e2b3c4d-5f6a-4789-9b23-d4e5f6a71829">
        <File Id="DriverInfFile" Source="$(var.BinDir)\driver\safechain_lib_l4_proxy_windows_driver.inf" KeyPath="yes" />
      </Component>
      <Component Id="DriverCat" Guid="6d3c4d5e-6f7b-4f89-ac34-e5f6a71829ba">
        <File Id="DriverCatFile" Source="$(var.BinDir)\driver\safechain_lib_l4_proxy_windows_driver.cat" KeyPath="yes" />
      </Component>
      <Component Id="DriverCer" Guid="5e4d5e6f-7a8c-4f89-9b45-f6a71829bacb">
        <File Id="DriverCerFile" Source="$(var.BinDir)\driver\safechain-driver.cer" KeyPath="yes" />
      </Component>
    </ComponentGroup>
    <?endif?>

    <DirectoryRef Id="SCRIPTSDIR">
      <Component Id="StoreTokenScript" Guid="d1e2f3a4-5b6c-7d8e-9f0a-1b2c3d4e5f6a">
        <File Id="StoreTokenPs1" Source="$(var.ProjectDir)\packaging\windows\scripts\StoreToken.ps1" KeyPath="yes" />
      </Component>
      <?if $(var.IncludeDriver) = "1" ?>
      <Component Id="InstallDriverScript" Guid="4f5e6f7a-8b9d-4cf9-ab56-71829bacbdce">
        <File Id="InstallDriverPs1" Source="$(var.ProjectDir)\packaging\windows\scripts\install-driver.ps1" KeyPath="yes" />
      </Component>
      <Component Id="UninstallDriverScript" Guid="3a6f7a8b-9c0e-4ff9-ac67-829bacbdcef0">
        <File Id="UninstallDriverPs1" Source="$(var.ProjectDir)\packaging\windows\scripts\uninstall-driver.ps1" KeyPath="yes" />
      </Component>
      <?endif?>
    </DirectoryRef>

    <!-- Add to PATH -->
    <DirectoryRef Id="BINDIR">
      <Component Id="PathComponent" Guid="5809b6b6-57a0-4c2a-9d55-7b274ceb916a">
        <Environment Id="PATH" Name="PATH" Value="[BINDIR]" Permanent="no" Part="last" Action="set" System="yes" />
      </Component>
    </DirectoryRef>

    <!-- Custom action to run teardown on uninstall (runs elevated before files are removed) -->
    <CustomAction Id="RunTeardown"
                  FileRef="AikidoAgentExeFile"
                  ExeCommand="--teardown"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <SetProperty Id="WriteAikidoToken" Before="WriteAikidoToken" Sequence="execute"
                 Condition="AIKIDO_TOKEN"
                 Value="&quot;[WindowsFolder]System32\WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[SCRIPTSDIR]StoreToken.ps1&quot; -Token &quot;[AIKIDO_TOKEN]&quot;" />
    <CustomAction Id="WriteAikidoToken"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <?if $(var.IncludeDriver) = "1" ?>
    <!-- Install the L4 driver: trust bundled cert, then pnputil /add-driver /install -->
    <SetProperty Id="InstallDriverPackage" Before="InstallDriverPackage" Sequence="execute"
                 Value="&quot;[WindowsFolder]System32\WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[SCRIPTSDIR]install-driver.ps1&quot; -DriverDir &quot;[DRIVERDIR]&quot;" />
    <CustomAction Id="InstallDriverPackage"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!-- Uninstall the L4 driver: pnputil /delete-driver /uninstall /force -->
    <SetProperty Id="UninstallDriverPackage" Before="UninstallDriverPackage" Sequence="execute"
                 Value="&quot;[WindowsFolder]System32\WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[SCRIPTSDIR]uninstall-driver.ps1&quot;" />
    <CustomAction Id="UninstallDriverPackage"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />
    <?endif?>

    <InstallExecuteSequence>
      <?if $(var.IncludeDriver) = "1" ?>
      <Custom Action="UninstallDriverPackage" Before="RunTeardown" Condition="(REMOVE~=&quot;ALL&quot;)" />
      <?endif?>
      <Custom Action="RunTeardown" Before="RemoveFiles" Condition="(REMOVE~=&quot;ALL&quot;)" />
      <?if $(var.IncludeDriver) = "1" ?>
      <Custom Action="InstallDriverPackage" After="InstallFiles" Condition="NOT (REMOVE~=&quot;ALL&quot;)" />
      <?endif?>
      <Custom Action="WriteAikidoToken" Before="StartServices" Condition="AIKIDO_TOKEN" />
    </InstallExecuteSequence>

    <!-- Cleanup ProgramData on uninstall -->
    <DirectoryRef Id="APPDATAAGENT">
      <Component Id="CleanupProgramData" Guid="c7e8f9a1-2b3c-4d5e-6f7a-8b9c0d1e2f3a">
        <RemoveFile Id="RemoveLogsFiles" Directory="APPDATALOGSDIR" Name="*" On="uninstall" />
        <RemoveFile Id="RemoveRunFiles" Directory="APPDATARUNDIR" Name="*" On="uninstall" />
        <RemoveFile Id="RemoveBinFiles" Directory="APPDATABINDIR" Name="*" On="uninstall" />
        <RemoveFile Id="RemoveAgentFiles" Name="*" On="uninstall" />
        <RemoveFolder Id="RemoveLogsDir" Directory="APPDATALOGSDIR" On="uninstall" />
        <RemoveFolder Id="RemoveRunDir" Directory="APPDATARUNDIR" On="uninstall" />
        <RemoveFolder Id="RemoveBinDir" Directory="APPDATABINDIR" On="uninstall" />
        <RemoveFolder Id="RemoveAgentDir" Directory="APPDATAAGENT" On="uninstall" />
        <RemoveFolder Id="RemoveAikidoDir" Directory="APPDATAAIKIDO" On="uninstall" />
      </Component>
    </DirectoryRef>

    <!-- UI with license and Aikido token dialog -->
    <WixVariable Id="WixUILicenseRtf" Value="$(var.ProjectDir)\packaging\windows\license.rtf" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />
    <UIRef Id="WixUI_InstallDir_Custom" />

  </Package>
</Wix>
