#!/bin/bash

set -e

echo "Aikido Endpoint Protection Installer - Post-installation"

EP_APP="/Applications/Aikido Endpoint Protection.app"
EP_BIN_DIR="$EP_APP/Contents/Resources/bin"
EP_SCRIPTS_DIR="$EP_APP/Contents/Resources/scripts"
RUN_DIR="/Library/Application Support/AikidoSecurity/EndpointProtection/run"
LOGS_DIR="/Library/Logs/AikidoSecurity/EndpointProtection"
LAUNCHDAEMON_PLIST="/Library/LaunchDaemons/com.aikidosecurity.endpointprotection.plist"

L4_APP="/Applications/Aikido Network Extension.app"

echo "Setting up directories..."
mkdir -p "$LOGS_DIR"
mkdir -p "$RUN_DIR"
chmod 755 "$LOGS_DIR"

echo "Setting permissions on binaries..."
chmod 755 "$EP_BIN_DIR/endpoint-protection"

if [ -d "$EP_APP" ]; then
    chmod -R 755 "$EP_APP"
else
    echo "Warning: App bundle not found at $EP_APP"
fi
chmod 755 "$EP_BIN_DIR/safechain-l7-proxy"

if [ -d "$L4_APP" ]; then
    echo "Registering L4 proxy app..."
    /System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister -f "$L4_APP"
    echo "L4 proxy app registered (system extension activation is handled by the host app)"
else
    echo "Warning: L4 proxy app not found at $L4_APP"
fi

echo "Setting ownership..."
chown -R root:wheel "$EP_APP"
chown -R root:wheel "$LOGS_DIR"
chown -R root:wheel "$RUN_DIR"

AIKIDO_TOKEN=""
CONFIG_FILE="$RUN_DIR/config.json"
TOKEN_STAGING_FILE="/tmp/aikido_endpoint_token.txt"

# 1) Explicit token via staging file always wins (fresh install or re-provisioning)
if [ -f "$TOKEN_STAGING_FILE" ]; then
    AIKIDO_TOKEN="$(cat "$TOKEN_STAGING_FILE" | tr -d '[:space:]')"
    rm -f "$TOKEN_STAGING_FILE"
fi

# 2) No staging file — check if this is an upgrade with an existing config
if [ -z "$AIKIDO_TOKEN" ] && [ -f "$CONFIG_FILE" ]; then
    EXISTING_TOKEN="$(sed -n 's/.*"token"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$CONFIG_FILE" | tr -d '[:space:]')"
    if [ -n "$EXISTING_TOKEN" ]; then
        echo "Existing token found in config, skipping token setup (upgrade)."
    fi
fi

if [ -n "$AIKIDO_TOKEN" ]; then
    echo "Storing Aikido token..."
    echo '{"token":"'"$AIKIDO_TOKEN"'"}' > "$CONFIG_FILE"
    chmod 600 "$CONFIG_FILE"
    chown root:wheel "$CONFIG_FILE"
fi

if [ -f "$LAUNCHDAEMON_PLIST" ]; then
    echo "Loading LaunchDaemon..."
    if ! launchctl bootstrap system "$LAUNCHDAEMON_PLIST" 2>&1; then
        echo "Bootstrap failed, trying load..."
        if ! launchctl load "$LAUNCHDAEMON_PLIST" 2>&1; then
            echo "Error: Failed to load LaunchDaemon" >&2
        fi
    fi

    sleep 2
    if launchctl list | grep -q "com.aikidosecurity.endpointprotection"; then
        echo "Aikido Endpoint Protection daemon installed and started"
    else
        echo "Warning: Daemon may not have started. Check logs at $LOGS_DIR"
    fi
else
    echo "Warning: LaunchDaemon plist not found at $LAUNCHDAEMON_PLIST"
fi

echo "Post-installation completed"
echo ""
echo "Aikido Endpoint Protection has been installed successfully!"
echo "  App: $EP_APP"
echo "  Logs: $LOGS_DIR"
echo ""
echo "The agent is now running as a system daemon."

exit 0
