#!/bin/bash

# =============================================================================
# Aikido Endpoint Protection - Uninstall Script
# =============================================================================
# Usage:
#   sudo ./uninstall             Full uninstall (removes everything)
#   sudo ./uninstall --upgrade   Pre-upgrade cleanup (preserves config, logs,
#                                and package receipt)
# =============================================================================

set -e

UPGRADE_MODE=false
if [ "$1" = "--upgrade" ]; then
    UPGRADE_MODE=true
fi

EP_APP="/Applications/Aikido Endpoint Protection.app"
EP_BIN_DIR="$EP_APP/Contents/Resources/bin"
SUPPORT_DIR="/Library/Application Support/AikidoSecurity/EndpointProtection"
LOGS_DIR="/Library/Logs/AikidoSecurity/EndpointProtection"
LAUNCHDAEMON_PLIST="/Library/LaunchDaemons/com.aikidosecurity.endpointprotection.plist"
DAEMON_LABEL="com.aikidosecurity.endpointprotection"
BINARY="$EP_BIN_DIR/endpoint-protection"

if [ "$UPGRADE_MODE" = true ]; then
    echo "Aikido Endpoint Protection - Pre-upgrade cleanup"
else
    echo "========================================="
    echo "Aikido Endpoint Protection - Uninstaller"
    echo "========================================="
fi
echo ""

if [ "$(id -u)" -ne 0 ]; then
    echo "Error: This script must be run as root (use sudo)"
    exit 1
fi

L4_APP="/Applications/Aikido Network Extension.app"
L4_HOST="$L4_APP/Contents/MacOS/Aikido Network Extension"

echo "Stopping Aikido Endpoint Protection processes..."

if [ -x "$L4_HOST" ]; then
    echo "  Stopping L4 transparent proxy..."
    if [ "$UPGRADE_MODE" = true ]; then
        "$L4_HOST" stop 2>/dev/null && echo "  ✓ L4 Proxy stopped" || echo "  L4 Proxy not running"
    else
        "$L4_HOST" stop --clean-secrets --remove-profile --deactivate-extension 2>/dev/null && echo "  ✓ L4 Proxy stopped" || echo "  L4 Proxy not running"
    fi
fi

if [ -f "$BINARY" ]; then
    echo "  Running teardown..."
    "$BINARY" --teardown 2>/dev/null && echo "  ✓ Teardown complete" || echo "  Teardown skipped (may already be torn down)"
fi

if launchctl list | grep -q "$DAEMON_LABEL"; then
    echo "  Stopping daemon via launchctl..."
    launchctl bootout system/"$DAEMON_LABEL" 2>/dev/null || {
        echo "  Trying alternative unload method..."
        launchctl unload "$LAUNCHDAEMON_PLIST" 2>/dev/null || true
    }
    echo "  ✓ Daemon stopped"
else
    echo "  Daemon not running"
fi

pkill -f "endpoint-protection-ui" 2>/dev/null && echo "  ✓ UI process stopped" || echo "  UI process not running"
pkill -f "safechain-l7-proxy" 2>/dev/null && echo "  ✓ L7 Proxy process stopped" || echo "  L7 Proxy process not running"
pkill -f "endpoint-protection" 2>/dev/null && echo "  ✓ Daemon process stopped" || echo "  Daemon process not running"

echo "  Waiting for processes to exit..."
for i in $(seq 1 10); do
    if ! pgrep -f "endpoint-protection" >/dev/null 2>&1; then
        break
    fi
    sleep 1
done

if pgrep -f "endpoint-protection" >/dev/null 2>&1; then
    echo "  Force-killing remaining processes..."
    pkill -9 -f "endpoint-protection" 2>/dev/null || true
    sleep 1
fi

echo ""
echo "Removing installed files..."

if [ -f "$LAUNCHDAEMON_PLIST" ]; then
    rm -f "$LAUNCHDAEMON_PLIST"
    echo "  ✓ Removed LaunchDaemon plist"
fi

if [ -d "$L4_APP" ]; then
    rm -rf "$L4_APP"
    echo "  ✓ Removed Aikido Network Extension app"
fi

if [ -d "$EP_APP" ]; then
    rm -rf "$EP_APP"
    echo "  ✓ Removed Aikido Endpoint Protection app"
fi

if [ "$UPGRADE_MODE" = false ]; then
    if [ -d "$SUPPORT_DIR" ]; then
        rm -rf "$SUPPORT_DIR"
        echo "  ✓ Removed application support files"
    fi

    if [ -d "$LOGS_DIR" ]; then
        rm -rf "$LOGS_DIR"
        echo "  ✓ Removed log files"
    fi

    AIKIDO_DIR="/Library/Application Support/AikidoSecurity"
    if [ -d "$AIKIDO_DIR" ] && [ -z "$(ls -A "$AIKIDO_DIR" 2>/dev/null)" ]; then
        rmdir "$AIKIDO_DIR" 2>/dev/null || true
        echo "  ✓ Removed empty AikidoSecurity directory"
    fi

    AIKIDO_LOGS_DIR="/Library/Logs/AikidoSecurity"
    if [ -d "$AIKIDO_LOGS_DIR" ] && [ -z "$(ls -A "$AIKIDO_LOGS_DIR" 2>/dev/null)" ]; then
        rmdir "$AIKIDO_LOGS_DIR" 2>/dev/null || true
        echo "  ✓ Removed empty AikidoSecurity logs directory"
    fi

    echo ""
    echo "Removing package receipt..."
    pkgutil --forget com.aikidosecurity.endpointprotection 2>/dev/null && echo "  ✓ Package receipt removed" || echo "  Package receipt not found"

    echo ""
    echo "========================================="
    echo "✓ Aikido Endpoint Protection has been uninstalled"
    echo "========================================="
fi

echo ""

exit 0
