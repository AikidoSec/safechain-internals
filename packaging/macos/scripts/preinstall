#!/bin/bash

set -e

echo "Aikido Endpoint Protection Installer - Pre-installation"

L4_HOST="/Applications/Aikido Proxy.app/Contents/MacOS/Aikido Proxy"

if [ -x "$L4_HOST" ]; then
    echo "Stopping L4 transparent proxy..."
    "$L4_HOST" stop --remove-profile --clean-secrets --deactivate-extension 2>/dev/null || true
fi

if launchctl list | grep -q "com.aikidosecurity.endpointprotection"; then
    echo "Stopping existing Aikido Endpoint Protection daemon..."
    launchctl bootout system/com.aikidosecurity.endpointprotection 2>/dev/null || true
fi

if [ -f "/Library/LaunchDaemons/com.aikidosecurity.endpointprotection.plist" ]; then
    echo "Removing old LaunchDaemon configuration..."
    rm -f "/Library/LaunchDaemons/com.aikidosecurity.endpointprotection.plist"
fi

echo "Pre-installation completed"

exit 0
