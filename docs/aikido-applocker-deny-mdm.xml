<RuleCollection Type="Msi" EnforcementMode="Enabled">
  <FilePublisherRule Id="c0a1b2c3-d4e5-46f7-8a9b-0c1d2e3f4a5b" Name="Deny - Aikido Endpoint Protection (block uninstall/repair)" Description="Prevents non-admin removal of the Aikido agent via Windows Installer" UserOrGroupSid="S-1-1-0" Action="Deny">
    <Conditions>
      <FilePublisherCondition PublisherName="O=AIKIDO SECURITY BV, L=GENT, S=OOST-VLAANDEREN, C=BE" ProductName="AIKIDO ENDPOINT PROTECTION" BinaryName="*">
        <BinaryVersionRange LowSection="*" HighSection="*" />
      </FilePublisherCondition>
    </Conditions>
  </FilePublisherRule>
  <FilePublisherRule Id="e1f2a3b4-c5d6-47e8-9f0a-1b2c3d4e5f60" Name="(Default) All signed Windows Installer files" Description="" UserOrGroupSid="S-1-1-0" Action="Allow">
    <Conditions><FilePublisherCondition PublisherName="*" ProductName="*" BinaryName="*"><BinaryVersionRange LowSection="*" HighSection="*" /></FilePublisherCondition></Conditions>
  </FilePublisherRule>
  <FilePathRule Id="f2a3b4c5-d6e7-48f9-a0b1-2c3d4e5f6071" Name="(Default) %WINDIR%\Installer" Description="" UserOrGroupSid="S-1-1-0" Action="Allow">
    <Conditions><FilePathCondition Path="%WINDIR%\Installer\*" /></Conditions>
  </FilePathRule>
  <FilePathRule Id="a3b4c5d6-e7f8-49a0-b1c2-3d4e5f607182" Name="(Default) All MSI for Administrators" Description="" UserOrGroupSid="S-1-5-32-544" Action="Allow">
    <Conditions><FilePathCondition Path="*" /></Conditions>
  </FilePathRule>
</RuleCollection>
